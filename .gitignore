# =============================================================================
# HyperLocal monorepo — production .gitignore
# Flutter · Node.js · Next.js · VS Code · macOS · Windows
# =============================================================================

# =============================================================================
# Dependencies
# =============================================================================
node_modules/
.pnp
.pnp.js
.pnp.cjs
.pnpm-store/
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions

# =============================================================================
# Node.js / package managers
# =============================================================================
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
*.tsbuildinfo
.node_repl_history
.npm
.eslintcache
.stylelintcache

# =============================================================================
